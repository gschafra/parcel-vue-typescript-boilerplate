{
	"name": "parcel-vue-ts-test",
	"version": "0.0.1",
	"description": "parce vue typescript test project",
	"source": "src/index.html",
	"scripts": {
		"dev": "parcel serve ./src/index.html --dist-dir ./dist --open",
		"build": "cross-env NODE_ENV=production parcel build src/index.html --no-source-maps --public-url .",
		"clean": "rimraf .cache/ && rimraf dist/ && rimraf build/",
		"compile:config": "tsc -m commonjs --esModuleInterop vue.config.ts",
		"test:unit": "jest --no-cache",
		"test:coverage": "jest --no-cache --coverage",
		"predeploy": "yarn run build"
	},
	"author": "Masonz <masonzone@gmail.com>",
	"license": "MIT",
	"devDependencies": {
		"@parcel/compressor-gzip": "^2.16.3",
		"@parcel/config-default": "^2.16.3",
		"@parcel/plugin": "^2.16.3",
		"@parcel/transformer-raw": "^2.16.3",
		"@parcel/transformer-typescript-tsc": "^2.16.3",
		"@parcel/transformer-vue": "^2.16.3",
		"@parcel/validator-typescript": "^2.16.3",
		"@stylistic/eslint-plugin": "^5.6.1",
		"@types/node": "^22",
		"@typescript-eslint/eslint-plugin": "^8.51.0",
		"@typescript-eslint/parser": "^8.51.0",
		"@vue/cli": "^5.0.9",
		"@vue/cli-service": "^5.0.9",
		"@vue/compiler-sfc": "^3.5.26",
		"@vue/component-compiler-utils": "^3.3.0",
		"@vue/eslint-config-typescript": "^14.6.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/vue3-jest": "^29.2.6",
		"autoprefixer": "^10.4.23",
		"babel-core": "^6.26.3",
		"babel-jest": "^30.2.0",
		"babel-plugin-module-resolver": "^5.0.2",
		"babel-plugin-transform-runtime": "^6.23.0",
		"babel-preset-es2015": "^6.24.1",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.2",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-import-quotes": "^0.0.1",
		"eslint-plugin-vue": "^10.6.2",
		"jest": "^30.2.0",
		"jest-serializer-vue": "^3.1.0",
		"parcel": "^2.16.3",
		"parcel-resolver-pnpm": "^0.0.1",
		"parcel-resolver-typescript-esm": "^1.0.1",
		"postcss": "^8.5.6",
		"prettier": "^3.7.4",
		"rimraf": "^6.1.2",
		"sass": "^1.97.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@primeuix/themes": "^2.0.2",
		"@primeuix/utils": "^0.6.3",
		"core-js": "^3.47.0",
		"primeicons": "^7.0.0",
		"primevue": "^4.5.4",
		"tsyringe": "^4.10.0",
		"vue": "^3.5.26",
		"vue-facing-decorator": "^4.0.1",
		"vue-hot-reload-api": "^2.3.4",
		"vue-router": "^4.6.4",
		"vuex": "^4.1.0",
		"vuex-facing-decorator": "^1.2.7"
	},
	"browserslist": [
		"> 0.2%",
		"not dead"
	],
	"jest": {
		"moduleFileExtensions": [
			"js",
			"vue"
		],
		"transform": {
			"^.+\\.js$": "<rootDir>/node_modules/babel-jest",
			".*\\.(vue)$": "<rootDir>/node_modules/vue-jest"
		},
		"mapCoverage": true,
		"coverageDirectory": "./coverage/",
		"collectCoverage": true
	},
	"publishConfig": {
		"access": "public"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"svgo": "2.8.0"
			}
		},
		"onlyBuiltDependencies": [
			"@apollo/protobufjs",
			"@parcel/watcher",
			"@swc/core",
			"core-js",
			"lmdb",
			"msgpackr-extract",
			"unrs-resolver"
		]
	},
	"@parcel/resolver-default": {
		"packageExports": true
	},
	"volta": {
		"node": "22.21.1",
		"pnpm": "10.27.0"
	}
}
